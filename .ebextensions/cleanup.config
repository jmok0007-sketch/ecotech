files:
  "/opt/elasticbeanstalk/hooks/appdeploy/post/cleanup_pycache.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      find /var/app/current -name "__pycache__" -type d -exec rm -rf {} +  2>/dev/null || true
      find /var/app/current -name "*.pyc" -delete 2>/dev/null || true
      echo "Python cache cleared"
